{
  "name": "Match Candidates",
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [],
  "nodes": [
    {
      "id": "webhook-trigger-match",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "webhookId": "match-candidates",
      "parameters": {
        "httpMethod": "POST",
        "path": "match-candidates",
        "responseMode": "lastNode",
        "options": {}
      }
    },
    {
      "id": "openai-embed-jd",
      "name": "OpenAI - Embed JD",
      "type": "n8n-nodes-base.openAi",
      "position": [450, 300],
      "parameters": {
        "operation": "createEmbedding",
        "model": "text-embedding-3-small",
        "input": "={{ $('Webhook').item.json.jd }}",
        "options": {}
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": "OpenAI account"
        }
      }
    },
    {
      "id": "mongodb-vector-search",
      "name": "MongoDB - Vector Search",
      "type": "n8n-nodes-base.mongoDb",
      "position": [650, 300],
      "parameters": {
        "operation": "aggregate",
        "collection": "resumes",
        "database": "getdeveloper",
        "query": "=[{\"$vectorSearch\": {\"index\": \"resume_vector_index\", \"path\": \"embedding\", \"queryVector\": {{ $('OpenAI - Embed JD').item.json.embedding }}, \"numCandidates\": 100, \"limit\": 20}}]"
      },
      "credentials": {
        "mongoDb": {
          "id": "",
          "name": "MongoDB account"
        }
      }
    },
    {
      "id": "code-format-candidates",
      "name": "Code - Format Candidates",
      "type": "n8n-nodes-base.code",
      "position": [850, 300],
      "parameters": {
        "jsCode": "const candidates = $input.all()[0].json;\n\nconst formatted = candidates.map((c, i) => {\n  const text = c.parsed_text ? c.parsed_text.substring(0, 1200) : '';\n  return `Candidate ${i+1}:\nFile: ${c.filename || 'Unknown'}\nText: ${text}`;\n}).join('\n\n---\n\n');\n\nreturn [{\n  json: {\n    candidates_text: formatted,\n    candidate_list: candidates\n  }\n}];",
        "language": "javaScript"
      }
    },
    {
      "id": "openai-generate-scores",
      "name": "OpenAI - Generate Scores",
      "type": "n8n-nodes-base.openAi",
      "position": [1050, 300],
      "parameters": {
        "operation": "sendMessage",
        "model": "gpt-4o-mini",
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "You are a recruiter AI. Given a job description and candidate profiles, return a STRICT JSON array.\nEach item must have these exact fields:\n- drive_file_id (string)\n- filename (string)\n- match_score (number 0-100)\n- skills_match (number 0-100)\n- experience_match (number 0-100)\n- domain_fit (number 0-100)\n- explanation (string, 2 sentences max)\n- strengths (array of strings, max 3)\n- gaps (array of strings, max 3)\n\nReturn ONLY valid JSON array. No markdown, no explanation, just JSON."
            },
            {
              "role": "user",
              "content": "Job Description:\n{{ $('Webhook').item.json.jd }}\n\nCandidates:\n{{ $json.candidates_text }}"
            }
          ]
        },
        "options": {
          "responseFormat": {
            "type": "json_object"
          }
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": "OpenAI account"
        }
      }
    },
    {
      "id": "respond-webhook-match",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1250, 300],
      "parameters": {
        "options": {},
        "statusCode": 200,
        "body": "={{ $json }}"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
