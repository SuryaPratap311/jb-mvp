    {
      "id": "openai-embed-jd",
      "name": "OpenAI - Embed JD",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "resource": "text",
        "operation": "customApiCall",
        "requestMethod": "POST",
        "url": "/embeddings",
        "jsonParameters": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "model",
