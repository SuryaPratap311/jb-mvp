{
  "name": "Drive Sync",
  "active": false,
  "settings": {
    "executionOrder": "v1"
  },
  "tags": [],
  "nodes": [
    {
      "id": "webhook-trigger",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "webhookId": "drive-sync",
      "parameters": {
        "httpMethod": "POST",
        "path": "drive-sync",
        "responseMode": "lastNode",
        "options": {}
      }
    },
    {
      "id": "google-drive-search",
      "name": "Google Drive - Search Files",
      "type": "n8n-nodes-base.googleDrive",
      "position": [450, 300],
      "parameters": {
        "operation": "search",
        "searchMethod": "query",
        "query": "mimeType='application/pdf'",
        "fields": ["id", "name", "mimeType", "modifiedTime", "size"],
        "options": {
          "pageSize": 1000
        }
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "",
          "name": "Google Drive account"
        }
      }
    },
    {
      "id": "split-batches",
      "name": "Split In Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "position": [650, 300],
      "parameters": {
        "batchSize": 1,
        "options": {}
      }
    },
    {
      "id": "google-drive-download",
      "name": "Google Drive - Download File",
      "type": "n8n-nodes-base.googleDrive",
      "position": [850, 300],
      "parameters": {
        "operation": "download",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.id }}",
          "mode": "id"
        },
        "options": {
          "binaryPropertyName": "data"
        }
      },
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "",
          "name": "Google Drive account"
        }
      }
    },
    {
      "id": "code-parse-pdf",
      "name": "Code - Parse PDF",
      "type": "n8n-nodes-base.code",
      "position": [1050, 300],
      "parameters": {
        "jsCode": "import io\nfrom pypdf import PdfReader\n\npdf_bytes = items[0].json['data']\nreader = PdfReader(io.BytesIO(pdf_bytes))\ntext = \"\"\nfor page in reader.pages:\n    page_text = page.extract_text()\n    if page_text:\n        text += page_text + \"\\n\"\n\nreturn [{\n    \"json\": {\n        \"drive_file_id\": items[0].json.get('id'),\n        \"filename\": items[0].json.get('name'),\n        \"parsed_text\": text[:30000],\n        \"mime_type\": items[0].json.get('mimeType'),\n        \"modified_time\": items[0].json.get('modifiedTime'),\n        \"file_size\": items[0].json.get('size')\n    }\n}]",
        "language": "python"
      }
    },
    {
      "id": "openai-embedding",
      "name": "OpenAI - Create Embedding",
      "type": "n8n-nodes-base.openAi",
      "position": [1250, 300],
      "parameters": {
        "operation": "createEmbedding",
        "model": "text-embedding-3-small",
        "input": "={{ $json.parsed_text }}",
        "options": {}
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": "OpenAI account"
        }
      }
    },
    {
      "id": "mongodb-insert",
      "name": "MongoDB - Insert/Update",
      "type": "n8n-nodes-base.mongoDb",
      "position": [1450, 300],
      "parameters": {
        "operation": "insert",
        "collection": "resumes",
        "database": "getdeveloper",
        "updateKey": "drive_file_id",
        "upsert": true,
        "document": "={\"drive_file_id\": \"{{ $json.drive_file_id }}\", \"filename\": \"{{ $json.filename }}\", \"parsed_text\": \"{{ $json.parsed_text }}\", \"embedding\": {{ $('OpenAI - Create Embedding').item.json.embedding }}, \"file_meta\": {\"mime_type\": \"{{ $json.mime_type }}\", \"size\": {{ $json.file_size }}, \"drive_modified_time\": \"{{ $json.modified_time }}\"}, \"updated_at\": \"{{ $now }}\"}"
      },
      "credentials": {
        "mongoDb": {
          "id": "",
          "name": "MongoDB account"
        }
      }
    },
    {
      "id": "respond-webhook",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [1650, 300],
      "parameters": {
        "options": {},
        "statusCode": 200,
        "body": "={\"synced\": \"success\", \"file\": \"{{ $json.filename }}\"}"
      }
    }
  ],
  "connections": {
    "Webhook": {
      "main": [
        [
          {
            "node": "Google Drive - Search Files",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Drive - Search Files": {
      "main": [
        [
          {
            "node": "Split In Batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Split In Batches": {
      "main": [
        [
          {
            "node": "Google Drive - Download File",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Google Drive - Download File": {
      "main": [
        [
          {
            "node": "Code - Parse PDF",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Code - Parse PDF": {
      "main": [
        [
          {
            "node": "OpenAI - Create Embedding",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "OpenAI - Create Embedding": {
      "main": [
        [
          {
            "node": "MongoDB - Insert/Update",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "MongoDB - Insert/Update": {
      "main": [
        [
          {
            "node": "Respond to Webhook",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}