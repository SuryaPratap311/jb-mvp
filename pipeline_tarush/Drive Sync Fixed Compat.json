        "jsCode": "const mergeData = $input.first().json;\n\nconst embedding =\n  mergeData.data?.[0]?.embedding ||\n  mergeData.embedding ||\n  [];\n\nreturn [{\n  json: {\n    drive_file_id: mergeData.drive_file_id || '',\n    filename: mergeData.filename || '',\n    parsed_text: mergeData.parsed_text || '',\n    embedding: embedding,\n    mime_type: mergeData.mime_type || '',\n    file_size: mergeData.file_size || '',\n    modified_time: mergeData.modified_time || ''\n  }\n}];"
