    {
      "parameters": {
        "jsCode": "const jd = $('Set JD').first().json.jd;\n\nconst seen = new Set();\nconst candidates = $input.all()\n  .map(item => item.json)\n  .filter(c => {\n    const key = c.drive_file_id || c.filename || c._id;\n    if (!key || seen.has(key)) return false;\n    seen.add(key);\n    return true;\n  })\n  .filter(c => {\n    const text = (c.parsed_text || '').trim();\n    return text &&\n      !text.includes('[No extractable text found]') &&\n      text.length > 80;\n  })\n  .slice(0, 10);\n\nconst formatted = candidates.map((c, i) => {\n  const text = (c.parsed_text || '').substring(0, 1200);\n  return `Candidate ${i + 1}:\ndrive_file_id: ${c.drive_file_id || 'Unknown'}\nFile: ${c.filename || 'Unknown'}\nText: ${text}`;\n}).join('\\n\\n---\\n\\n');\n\nreturn [{\n  json: {\n    jd,\n    candidates_text: formatted,\n    candidate_list: candidates\n  }\n}];"
      },
