    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const fileId = $('Split In Batches').item.json.id;\nconst fileName = $('Split In Batches').item.json.name;\nconst mimeType = $('Split In Batches').item.json.mimeType;\nconst modifiedTime = $('Split In Batches').item.json.modifiedTime;\nconst fileSize = $('Split In Batches').item.json.size;\n\nconst rawText = $json.text || $json.extractedText || $json.content || '';\nconst parsedText = rawText\n  .replace(/\\s+/g, ' ')\n  .replace(/\\u0000/g, '')\n  .trim()\n  .slice(0, 20000);\n\nreturn {\n  json: {\n    drive_file_id: fileId,\n    filename: fileName,\n    parsed_text: parsedText || `[File: ${fileName}] [No extractable text found]`,\n    mime_type: mimeType,\n    modified_time: modifiedTime,\n    file_size: fileSize,\n    has_text: !!parsedText\n  }\n};"
      },
