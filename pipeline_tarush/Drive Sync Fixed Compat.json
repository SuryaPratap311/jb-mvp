    {
      "parameters": {
        "jsCode": "const body = {\n  model: \"gpt-4o-mini\",\n  messages: [\n    {\n      role: \"system\",\n      content: `\nYou are a recruiter AI.\n\nUse only the candidate text provided.\nDo not invent skills, tools, projects, or experience.\nIf evidence is missing, score lower and explicitly mention that the evidence is missing.\nEach explanation must reference at least one concrete detail or phrase from the candidate text, or clearly state that the resume text does not provide enough evidence.\nAlways preserve the exact drive_file_id and filename from the input candidate block.\nDo not make up IDs, filenames, or candidate details.\nReturn exactly one ranking item for each candidate block provided in the input. Do not skip or merge candidates.\n\nReturn a STRICT JSON object with exactly one top-level key: \"rankings\".\n\nThe value of \"rankings\" must be an array.\n\nEach item in the array must contain:\n- drive_file_id (string)\n- filename (string)\n- match_score (number, 0-100)\n- skills_match (number, 0-100)\n- experience_match (number, 0-100)\n- domain_fit (number, 0-100)\n- explanation (string, maximum 2 sentences)\n- strengths (array of strings, maximum 3 items)\n- gaps (array of strings, maximum 3 items)\n\nReturn ONLY valid JSON.\nDo NOT include markdown.\nDo NOT include code fences.\nDo NOT include any text outside the JSON object.\n      `.trim(),\n    },\n    {\n      role: \"user\",\n      content:\n        \"Job Description: \" +\n        $input.first().json.jd +\n        \"\\n\\nCandidates:\\n\" +\n        $input.first().json.candidates_text,\n    },\n  ],\n  response_format: {\n    type: \"json_object\",\n  },\n};\n\nreturn [\n  {\n    json: {\n      requestBody: body,\n    },\n  },\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        4912,
        2112
      ],
      "id": "cd134cdf-d0ba-4fdc-9ae8-ef4d139d1fbd",
