    {
      "parameters": {
        "jsCode": "const jd = $('Set JD').first().json.jd;\nconst queryVector = $('Merge JD + Embedding').first().json.data[0].embedding;\n\nreturn [{\n  json: {\n    jd,\n    mongoQuery: [\n      {\n        $vectorSearch: {\n          index: \"resume_vector_index\",\n          path: \"embedding\",\n          queryVector,\n          numCandidates: 100,\n          limit: 10\n        }\n      }\n    ]\n  }\n}];"
      },
