    {
      "id": "openai-embed-jd",
      "name": "OpenAI - Embed JD",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [450, 300],
      "parameters": {
        "operation": "createEmbedding",
        "model": "text-embedding-3-small",
        "input": "={{ $json.jd }}",
