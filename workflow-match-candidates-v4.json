      }
    },
    {
      "id": "set-extract-embedding",
      "name": "Set - Extract Embedding",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [650, 300],
      "parameters": {
        "values": {
          "array": [
            {
              "name": "jd_embedding",
              "value": "={{ $json.embedding }}"
            }
          ]
        },
        "options": {}
      }
    },
    {
      "id": "mongodb-vector-search",
      "name": "MongoDB - Vector Search",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1,
      "position": [850, 300],
      "parameters": {
        "operation": "aggregate",
        "collection": "resumes",
        "database": "getdeveloper",
        "query": "=[{\"$vectorSearch\": {\"index\": \"resume_vector_index\", \"path\": \"embedding\", \"queryVector\": {{ $json.jd_embedding }}, \"numCandidates\": 100, \"limit\": 20}}]"
      },
      "credentials": {
        "mongoDb": {
          "id": "",
          "name": "MongoDB account"
        }
      }
    },
    {
      "id": "code-format-candidates",
      "name": "Code - Format Candidates",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst candidates = items[0]?.json || [];\n\nconst formatted = candidates.map((c, i) => {\n  const text = c.parsed_text ? c.parsed_text.substring(0, 1200) : '';\n  return `Candidate ${i+1}:\nFile: ${c.filename || 'Unknown'}\nText: ${text}`;\n}).join('\n\n---\n\n');\n\nreturn [{\n  json: {\n    candidates_text: formatted,\n    candidate_list: candidates\n  }\n}];"
      }
    },
    {
      "id": "openai-generate-scores",
      "name": "OpenAI - Generate Scores",
      "type": "n8n-nodes-base.openAi",
      "typeVersion": 1,
      "position": [1250, 300],
      "parameters": {
        "operation": "sendMessage",
        "model": "gpt-4o-mini",
        "messages": {
          "messageValues": [
            {
              "role": "system",
              "content": "You are a recruiter AI. Given a job description and candidate profiles, return a STRICT JSON array. Each item must have these exact fields: drive_file_id (string), filename (string), match_score (number 0-100), skills_match (number 0-100), experience_match (number 0-100), domain_fit (number 0-100), explanation (string, 2 sentences max), strengths (array of strings, max 3), gaps (array of strings, max 3). Return ONLY valid JSON array. No markdown, no explanation, just JSON."
            },
            {
              "role": "user",
              "content": "Job Description:\n{{ $('Webhook').item.json.jd }}\n\nCandidates:\n{{ $json.candidates_text }}"
            }
          ]
        },
        "options": {
          "responseFormat": {
            "type": "json_object"
          }
        }
      },
      "credentials": {
        "openAiApi": {
          "id": "",
          "name": "OpenAI account"
        }
      }
    },
    {
      "id": "code-parse-response",
      "name": "Code - Parse Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1450, 300],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\nconst content = items[0]?.json?.choices?.[0]?.message?.content;\nlet results = [];\n\ntry {\n  results = JSON.parse(content);\n  if (!Array.isArray(results)) {\n    results = [results];\n  }\n} catch (e) {\n  results = [{ error: 'Failed to parse OpenAI response', raw: content }];\n}\n\nreturn [{\n  json: {\n    matches: results,\n    count: results.length\n  }\n}];"
      }
    },
    {
      "id": "respond-webhook-match",
      "name": "Respond to Webhook",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1,
      "position": [1650, 300],
      "parameters": {
        "options": {},
        "statusCode": 200,
        "body": "={{ $json }}"
      }
    }
  ],
